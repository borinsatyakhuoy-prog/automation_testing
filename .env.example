# Copy this file to .env and fill in real values. .env is gitignored and must never be committed.
FAPA_BASE_URL=https://develop-fapa.allweb.cloud
FAPA_EMAIL=your-test-account-email@example.com
FAPA_PASSWORD=your-test-account-password
# Name of the client record to search for when generating/validating reports.
FAPA_REPORT_CLIENT_NAME=Your Test Client Name
# Name of the dedicated synthetic client used by the mail-service reset-password notification test.
FAPA_MAIL_TEST_CLIENT_NAME=Your Mail Test Client Name
# Credentials for a dedicated EMPLOYE-role test account (Admins > Team Management > Add user,
# then row menu > Reset password to set a known password) - used for role-scoped performance tests.
FAPA_EMPLOYEE_EMAIL=your-employee-test-account@example.com
FAPA_EMPLOYEE_PASSWORD=your-employee-test-password
# Credentials for a client-portal login (Clients > row menu > Reset password on an existing client
# record to set a known password) - used for role-scoped performance tests against the restricted
# client portal (Dashboard + Reports only).
FAPA_CLIENT_PORTAL_EMAIL=your-client-portal-test-account@example.com
FAPA_CLIENT_PORTAL_PASSWORD=your-client-portal-test-password
